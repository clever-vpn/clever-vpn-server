#!/bin/sh

# pre-push hook: prevent direct pushes to main branch
# This hook is managed by the repository's development workflow.
# See .github/copilot-instructions.md for details.

protected_branch="refs/heads/main"

while read local_ref local_oid remote_ref remote_oid; do
    if [ "$remote_ref" = "$protected_branch" ]; then
        echo "ERROR: Direct push to 'main' is not allowed!"
        echo "       Please create a feature branch and use a Pull Request instead."
        echo "       See .github/copilot-instructions.md for the full workflow."
        exit 1
    fi
done

exit 0
